Type: spec
Repotype: rpm-md sha512:rsyncable:zchunk:compression-zstd:filelists-ex

ExpandFlags: preinstallexpand

Release: <CI_CNT>.<B_CNT>%%{?dist}

PublishFilter: .*-bootstrap.*

Preinstall: rpm-build
Preinstall: gcc-c++

Required: rpm-config-openruyi

Support: perl-rpm-packaging
Support: glibc-gconv-modules-extra
Support: mold

Prefer: systemd-udev
Prefer: ninja
Prefer: shadow
Prefer: libevent
Prefer: libomp
Prefer: glib-devel glib
Prefer: python3-libs python3-devel
Prefer: python3 python3-packaging python3-pip python3-wheel
Prefer: rust

Prefer: libgcc-s
Prefer: libstdc++
Prefer: libgomp
Prefer: libatomic
Prefer: libquadmath
Prefer: libgfortran

Macros:
%dist .or
%_vendor openruyi
%ext_info .gz
%gcc_version 15
%bcond_override_default_systemd 1
%_with_systemd 1
%ext_man .gz
%__python /usr/bin/python3
%bcond_override_default_acl_tests 1
%__systemd_sysusers /usr/bin/systemd-sysusers
%autorelease 1%{?dist}
%autochangelog %{nil}
%_sbindir %_bindir
%_vendor_repo_url https://repo.build.openruyi.cn/openruyi/\\$basearch/
:Macros

FileProvides: /usr/bin/passwd busybox-adduser shadow
FileProvides: /usr/bin/useradd shadow
FileProvides: /usr/bin/userdel shadow
FileProvides: /usr/bin/usermod shadow
FileProvides: /usr/bin/dbus-daemon dbus-tools
FileProvides: /usr/bin/xsltproc libxslt
