-                (void)pysqlite_statement_reset((pysqlite_Statement*)statement);
-            } else {
-                (void)pysqlite_statement_finalize((pysqlite_Statement*)statement);
+        if (PyWeakref_GetRef(weakref, &statement) > 0) {
