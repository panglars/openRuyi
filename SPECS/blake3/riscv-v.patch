                             out);
@@ -327,6 +367,11 @@ size_t blake3_simd_degree(void) {
 #endif
 #if BLAKE3_USE_NEON == 1
   return 4;
+#endif
+#if BLAKE3_BUILD_RVV == 1
+  if (blake3_rvv_detected()) {
+    return blake3_rvv_simd_degree();
+  }
 #endif
