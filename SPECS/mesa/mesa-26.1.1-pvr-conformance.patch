From da58cd888405ef19aa7802b2178dd452a4e377bf Mon Sep 17 00:00:00 2001
From: Icenowy Zheng <zhengxingda@iscas.ac.cn>
Date: Mon, 27 Apr 2026 22:25:22 +0800
Subject: [PATCH 5/8] pvr: add a driconf option to advertise FILTER_LINEAR for
 LINEAR images

Wayland compositors want to sample from 2D linear images (contents of
the Wayland surfaces) with linear filtering.

However, this feature isn't thoroughly tested, and is known to cause
CTS failures about blitting from 3D linear images.

Add a driconf option to selectively advertise this feature for Wayland
compositors. Weston and wlroots are added to the allowlist, and their
sources are confirmed to have no reference to 3D linear images.

Signed-off-by: Icenowy Zheng <zhengxingda@iscas.ac.cn>
---
 src/imagination/vulkan/pvr_formats.c  | 17 ++++++++++++-----
 src/imagination/vulkan/pvr_instance.c |  7 +++++++
 src/imagination/vulkan/pvr_instance.h |  1 +
 src/util/00-mesa-defaults.conf        | 15 +++++++++++++++
 src/util/driconf.h                    |  8 ++++++++
 5 files changed, 43 insertions(+), 5 deletions(-)

diff --git a/src/imagination/vulkan/pvr_formats.c b/src/imagination/vulkan/pvr_formats.c
index b46a8454b79..1f40370daf7 100644
--- a/src/imagination/vulkan/pvr_formats.c
+++ b/src/imagination/vulkan/pvr_formats.c
@@ -34,6 +34,7 @@
 #include "pvr_csb.h"
 #include "pvr_device.h"
 #include "pvr_entrypoints.h"
+#include "pvr_instance.h"
 #include "pvr_limits.h"
 #include "pvr_formats.h"
 #include "pvr_macros.h"
@@ -262,12 +263,11 @@ pvr_get_image_format_features2(struct pvr_physical_device *pdevice,
       vk_format_get_ycbcr_info(vk_format);
 
    if (pvr_format->bind & PVR_BIND_SAMPLER_VIEW) {
+      const uint32_t first_component_size =
+         vk_format_get_component_bits(vk_format,
+                                      UTIL_FORMAT_COLORSPACE_RGB,
+                                      0);
       if (vk_tiling == VK_IMAGE_TILING_OPTIMAL) {
-         const uint32_t first_component_size =
-            vk_format_get_component_bits(vk_format,
-                                         UTIL_FORMAT_COLORSPACE_RGB,
-                                         0);
-
          flags |= VK_FORMAT_FEATURE_2_SAMPLED_IMAGE_BIT |
                   VK_FORMAT_FEATURE_2_TRANSFER_SRC_BIT |
                   VK_FORMAT_FEATURE_2_TRANSFER_DST_BIT;
@@ -289,6 +289,13 @@ pvr_get_image_format_features2(struct pvr_physical_device *pdevice,
                   VK_FORMAT_FEATURE_2_TRANSFER_SRC_BIT |
                   VK_FORMAT_FEATURE_2_TRANSFER_DST_BIT;
 
+         if (pdevice->instance->enable_linear_image_linear_filter &&
+             !vk_format_is_int(vk_format) &&
+             !vk_format_is_depth_or_stencil(vk_format) &&
+             first_component_size < 32) {
+            flags |= VK_FORMAT_FEATURE_2_SAMPLED_IMAGE_FILTER_LINEAR_BIT;
+	 }
+
          if (ycbcr_info) {
             flags |= VK_FORMAT_FEATURE_2_COSITED_CHROMA_SAMPLES_BIT;
          } else {
diff --git a/src/imagination/vulkan/pvr_instance.c b/src/imagination/vulkan/pvr_instance.c
index 52da6d884f5..6da953972c4 100644
--- a/src/imagination/vulkan/pvr_instance.c
+++ b/src/imagination/vulkan/pvr_instance.c
@@ -338,6 +338,10 @@ static const driOptionDescription pvr_dri_options[] = {
       DRI_CONF_VK_WSI_FORCE_SWAPCHAIN_TO_CURRENT_EXTENT(false)
       DRI_CONF_VK_X11_IGNORE_SUBOPTIMAL(false)
    DRI_CONF_SECTION_END
+
+   DRI_CONF_SECTION_MISCELLANEOUS
+      DRI_CONF_PVR_ENABLE_LINEAR_IMAGE_LINEAR_FILTER(false)
+   DRI_CONF_SECTION_END
 };
 /* clang-format on */
 
@@ -359,6 +363,9 @@ static void pvr_init_dri_options(struct pvr_instance *instance)
 
    instance->force_vk_vendor =
       driQueryOptioni(&instance->dri_options, "force_vk_vendor");
+   instance->enable_linear_image_linear_filter =
+      driQueryOptionb(&instance->dri_options,
+                      "pvr_enable_linear_image_linear_filter");
 }
 
 VkResult pvr_CreateInstance(const VkInstanceCreateInfo *pCreateInfo,
diff --git a/src/imagination/vulkan/pvr_instance.h b/src/imagination/vulkan/pvr_instance.h
index 497831b2f6d..135a0e406a2 100644
--- a/src/imagination/vulkan/pvr_instance.h
+++ b/src/imagination/vulkan/pvr_instance.h
@@ -31,6 +31,7 @@ struct pvr_instance {
 
    uint8_t driver_build_sha[BLAKE3_KEY_LEN];
    uint32_t force_vk_vendor;
+   bool enable_linear_image_linear_filter;
 };
 
 VK_DEFINE_HANDLE_CASTS(pvr_instance,
diff --git a/src/util/00-mesa-defaults.conf b/src/util/00-mesa-defaults.conf
index 6e130c80b94..00eff12f43c 100644
--- a/src/util/00-mesa-defaults.conf
+++ b/src/util/00-mesa-defaults.conf
@@ -1544,4 +1544,19 @@ TODO: document the other workarounds.
             <option name="allow_rgb16_configs" value="false"/>
         </application>
     </device>
+    <device driver="pvr">
+        <!--
+           The PowerVR hardware can do linear filtering on linear 2D images,
+           but not 3D ones. Wayland compositors will want this, and they
+           are known not to perform linear filtering on linear 3D images.
+        -->
+        <application name="weston" application_name_match="weston">
+            <!-- Weston does not use 3D images -->
+            <option name="pvr_enable_linear_image_linear_filter" value="true"/>
+        </application>
+        <engine engine_name_match="wlroots">
+            <!-- Wlroots only creates OPTIMAL tiled 3D images -->
+            <option name="pvr_enable_linear_image_linear_filter" value="true"/>
+        </engine>
+    </device>
 </driconf>
diff --git a/src/util/driconf.h b/src/util/driconf.h
index 5a73c15ac2f..a96b5c3849a 100644
--- a/src/util/driconf.h
+++ b/src/util/driconf.h
@@ -660,6 +660,14 @@
    DRI_CONF_OPT_B(pan_force_enable_shader_atomics, def, \
                   "Enable fragmentStoresAndAtomics and vertexPipelineStoresAndAtomics on any architecture. (This may not work reliably and is for debug purposes only!)")
 
+/**
+ * \brief powervr specific configuration options
+ */
+
+#define DRI_CONF_PVR_ENABLE_LINEAR_IMAGE_LINEAR_FILTER(def) \
+   DRI_CONF_OPT_B(pvr_enable_linear_image_linear_filter, def, \
+                  "Enable advertisement of linear filtering on linear images (which works for 2D images but not 3D ones)")
+
 /**
  * \brief Turnip specific configuration options
  */
-- 
